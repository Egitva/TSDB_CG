    {
      "id": 10,
      "name": "Кейкен",
      "type": "Лидер",
      "desc": "Переверните эту карту (Q)\nR: Добавьте добавьте из Колоды в руку карту с типом \"Тенто\" и \"Наре\" в имени.\nВ: Отправьте из руки оппонента в Null оппонента случайную карту с типом \"Тенто\"\nL: Когда вы активируете карту с типом \"Тенто\": Скиньте карту из руки в Null; Отправьте карту с типом \"Тенто\" из колоды в Aside. (2 раза за игру)",
      "atk": 180,
      "def": 200,
      "race": "Масочник",
      "attribute": "R",
      "card_images": [
        {
          "id": 10,
          "image_url": "/images/10.png"
        }
      ]
